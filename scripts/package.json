{
  "name": "licilibre-scripts",
  "version": "1.0.0",
  "description": "Scripts de fetch i normalització de licitacions públiques",
  "type": "module",
  "scripts": {
    "fetch:place": "node fetch-place.js",
    "fetch:ted": "node fetch-ted.js",
